// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---
// Role for user auth and RBAC
enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

// Appointment lifecycle and cancellation tracking
enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED_BY_PATIENT
  CANCELLED_BY_DOCTOR
  NO_SHOW
}

// File type for medical uploads (S3-ready)
enum FileType {
  REPORT
  IMAGE
  DOCUMENT
  OTHER
}

// Patient demographic (optional)
enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// --- User (auth + base identity) ---
// Includes fields for email verification and password reset
model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  passwordHash         String    @map("password_hash")
  role                 Role
  // Auth / verification
  emailVerified        Boolean?  @default(false) @map("email_verified")
  verificationToken    String?   @map("verification_token")
  passwordResetToken   String?   @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  // Audit
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  doctorProfile    DoctorProfile?
  patient          Patient?
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  uploadedFiles    File[]         @relation("UploadedFiles")
  ownedFiles       File[]         @relation("OwnedFiles")

  @@map("users")
}

// --- Doctor profile (extends User) ---
model DoctorProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  specialization     String // Indexed for patient search
  experienceYears    Int?     @map("experience_years")
  bio                String?
  consultationFee    Decimal? @map("consultation_fee") @db.Decimal(10, 2)
  registrationNumber String?  @map("registration_number")
  degree             String?
  verified           Boolean  @default(false) @map("verified")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability  DoctorAvailability[]
  appointments  Appointment[]
  prescriptions Prescription[]

  @@index([specialization])
  @@index([verified])
  @@map("doctor_profiles")
}

// --- Doctor availability (weekly time windows) ---
// Patients use this + existing appointments to see free slots
model DoctorAvailability {
  id           String   @id @default(uuid())
  doctorId     String   @map("doctor_id")
  weekday      Int // 0=Sunday, 6=Saturday
  startTime    String   @map("start_time") // HH:mm format (e.g. "09:00")
  endTime      String   @map("end_time") // HH:mm format (e.g. "17:00")
  slotDuration Int?     @default(30) @map("slot_duration") // minutes per slot
  bufferTime   Int?     @default(0) @map("buffer_time") // minutes between appointments
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  doctor DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, weekday])
  @@map("doctor_availability")
}

// --- Patient (extends User) ---
model Patient {
  id                    String    @id @default(uuid())
  userId                String    @unique @map("user_id")
  dateOfBirth           DateTime? @map("date_of_birth") @db.Date
  gender                Gender?
  phone                 String?   @map("phone")
  bloodGroup            String?   @map("blood_group")
  height                Int?      @map("height") // cm
  weight                Decimal?  @map("weight") @db.Decimal(5, 2) // kg
  emergencyContactName  String?   @map("emergency_contact_name")
  emergencyContactPhone String?   @map("emergency_contact_phone")
  city                  String?   @map("city")
  state                 String?   @map("state")
  address               String?   @map("address")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  prescriptions Prescription[]

  @@map("patients")
}

// --- Appointments ---
// Booking API must check for overlapping appointments (doctor + time range)
model Appointment {
  id               String            @id @default(uuid())
  patientId        String            @map("patient_id")
  doctorId         String            @map("doctor_id")
  scheduledAt      DateTime          @map("scheduled_at")
  durationMinutes  Int               @default(30) @map("duration_minutes")
  status           AppointmentStatus @default(PENDING)
  reason           String?
  // Video session
  videoRoomId      String?           @map("video_room_id")
  meetingLink      String?           @map("meeting_link")
  sessionStartedAt DateTime?         @map("session_started_at")
  sessionEndedAt   DateTime?         @map("session_ended_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor        DoctorProfile  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  messages      Message[]
  prescriptions Prescription[]
  files         File[]

  @@index([doctorId, scheduledAt])
  @@index([patientId, scheduledAt])
  @@map("appointments")
}

// --- Messages ---
model Message {
  id            String   @id @default(uuid())
  senderId      String   @map("sender_id")
  receiverId    String   @map("receiver_id")
  appointmentId String?  @map("appointment_id")
  content       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sender      User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User         @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
  @@index([senderId, receiverId, createdAt])
  @@map("messages")
}

// --- Prescriptions ---
model Prescription {
  id            String   @id @default(uuid())
  doctorId      String   @map("doctor_id")
  patientId     String   @map("patient_id")
  appointmentId String?  @map("appointment_id")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  doctor      DoctorProfile      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient     Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment?       @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  items       PrescriptionItem[]

  @@map("prescriptions")
}

// --- Prescription items (per-drug details) ---
model PrescriptionItem {
  id             String   @id @default(uuid())
  prescriptionId String   @map("prescription_id")
  drugName       String   @map("drug_name")
  dosage         String?
  frequency      String?
  duration       String?
  quantity       String?
  instructions   String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@map("prescription_items")
}

// --- Files (medical reports, S3-ready) ---
model File {
  id            String   @id @default(uuid())
  ownerId       String   @map("owner_id")
  appointmentId String?  @map("appointment_id")
  uploadedById  String   @map("uploaded_by_id")
  type          FileType
  storageKey    String   @map("storage_key") // S3 object key
  originalName  String   @map("original_name")
  mimeType      String   @map("mime_type")
  sizeBytes     BigInt   @map("size_bytes")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  owner       User         @relation("OwnedFiles", fields: [ownerId], references: [id], onDelete: Cascade)
  uploadedBy  User         @relation("UploadedFiles", fields: [uploadedById], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@map("files")
}
